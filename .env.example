# ============================================================
# Business Document Intelligence System — Environment Variables
# Copy this file to .env and fill in all values before running.
# ============================================================

# ---------------------------------------------------------------------------
# Google Gemini (embeddings — text-embedding-004, 768-dim)
# ---------------------------------------------------------------------------
GOOGLE_API_KEY=

# ---------------------------------------------------------------------------
# LLM — using Groq-hosted openai/gpt-oss-20b (OpenAI-compatible API)
# API key format: gsk_* (Groq key)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=            # Your Groq API key (gsk_...)
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=openai/gpt-oss-20b

# ---------------------------------------------------------------------------
# Pinecone (vector store — MUST be created with dimension=768 before first run)
# ---------------------------------------------------------------------------
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=doc-intelligence

# ---------------------------------------------------------------------------
# Supabase (Postgres DB + file storage)
# ---------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=   # Server-side only — never expose to browser
STORAGE_BUCKET=documents

# ---------------------------------------------------------------------------
# Internal service auth (shared secret between Next.js and FastAPI)
# ---------------------------------------------------------------------------
INTERNAL_API_KEY=change-me-in-production

# ---------------------------------------------------------------------------
# Vector store mode: "pinecone" (prod) | "chroma" (local dev)
# ---------------------------------------------------------------------------
VECTOR_STORE=pinecone

# ---------------------------------------------------------------------------
# RAG tuning — adjust after real document tests
# ---------------------------------------------------------------------------
CONFIDENCE_THRESHOLD=0.75    # Below this → "I don't know" (no LLM call)
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=5
CHAT_HISTORY_WINDOW=4        # Number of turns passed to LLM context window
